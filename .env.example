MCP_MOULINEUSE_URL=
MCP_MOULINEUSE_TOKEN=
ANTHROPIC_API_KEY=
PORT=3000
# Minimum confidence score (0-100) required for the Conseil des Mentors to
# certify a response instead of refusing.
CONFIDENCE_THRESHOLD=70
# Set to 1 to have mentors read fixtures/moulineuse/*.json instead of the live
# Moulineuse MCP (demo fallback if the live server is unavailable).
MOCK_MOULINEUSE=
# agentpush — dogfood delivery of a certified answer out-of-band
# (Telegram/mail). Both must be set to enable; the push is fire-and-forget and
# only fires when a response is certified (status "answered") AND the caller
# supplied channel/address in the /api/chat body. Leave empty to disable.
AGENTPUSH_BASE_URL=
AGENTPUSH_API_KEY=
