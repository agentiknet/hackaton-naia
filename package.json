{
  "name": "naia",
  "version": "0.1.0",
  "description": "Naia — governed parliamentary AI assistant (AN hackathon 2026)",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke:mcp": "tsx --env-file=.env src/scripts/smoke-mcp.ts",
    "smoke:claims": "tsx --env-file=.env src/scripts/smoke-claims.ts",
    "smoke:verify": "tsx --env-file=.env src/scripts/smoke-verify.ts",
    "smoke:pipeline": "tsx --env-file=.env src/scripts/smoke-pipeline.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.7",
    "@hono/node-server": "^1.13.0",
    "@mastra/core": "1.48.0",
    "@mastra/mcp": "^1.13.0",
    "ai": "^7.0.14",
    "hono": "^4.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
